<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-2">Zamówienie #<%= @order.id %></h1>
  <p class="text-gray-600 mb-6">Złożone: <%= @order.created_at.strftime("%d.%m.%Y %H:%M:%S") %></p>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Dane klienta</h2>
    <div class="grid grid-cols-2 gap-4">
      <div><strong>Imię i nazwisko:</strong> <%= @order.user.first_name %> <%= @order.user.last_name %></div>
      <div><strong>Email:</strong> <%= @order.user.email %></div>
      <div><strong>Telefon:</strong> <%= @order.user.phone %></div>
      <div class="col-span-2"><strong>Adres:</strong> <%= @order.user.address %></div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Produkty</h2>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left">Produkt</th>
          <th class="px-4 py-2 text-right">Cena</th>
          <th class="px-4 py-2 text-center">Ilość</th>
          <th class="px-4 py-2 text-right">Razem</th>
        </tr>
      </thead>
      <tbody>
        <% @order.order_items.each do |item| %>
          <tr>
            <td class="px-4 py-2"><%= item.product.name %></td>
            <td class="px-4 py-2 text-right"><%= number_to_currency(item.price) %></td>
            <td class="px-4 py-2 text-center"><%= item.quantity %></td>
            <td class="px-4 py-2 text-right"><%= number_to_currency(item.price * item.quantity) %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="bg-gray-100 font-bold">
        <tr>
          <td colspan="3" class="px-4 py-2 text-right">Razem:</td>
          <td class="px-4 py-2 text-right"><%= number_to_currency(@order.order_items.sum { |i| i.price * i.quantity }) %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="flex gap-4">
    <%= link_to "← Powrót do listy", admin_orders_path, class: "bg-gray-500 text-white px-4 py-2 rounded" %>
    <%= link_to "Edytuj status", admin_orders_path(anchor: "order_#{@order.id}"), class: "bg-indigo-600 text-white px-4 py-2 rounded" %>
  </div>
</div>