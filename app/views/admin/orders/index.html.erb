<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">Zarządzanie zamówieniami</h1>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Klient</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Adres</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Telefon</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Razem</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Akcje</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @orders.each do |order| %>
          <tr>
            <td class="px-6 py-4">#<%= order.id %></td>
            <td class="px-6 py-4"><%= order.user.first_name %> <%= order.user.last_name %></td>
            <td class="px-6 py-4"><%= order.user.email %></td>
            <td class="px-6 py-4"><%= order.user.address %></td>
            <td class="px-6 py-4"><%= order.user.phone %></td>
            <td class="px-6 py-4"><%= number_to_currency(order.total_price) %></td>
            <td class="px-6 py-4">
              <%= form_with model: order, url: admin_order_path(order), method: :patch, local: true, class: "flex gap-2" do |f| %>
                <%= f.select :status, options_for_select([['Nowe', 'nowe'], ['Opłacone', 'oplacone'], ['Wysłane', 'wyslane'], ['Dostarczone', 'dostarczone']], order.status), class: "border rounded px-2 py-1 text-sm" %>
                <%= f.submit "Zmień", class: "bg-indigo-600 text-white px-3 py-1 rounded text-sm hover:bg-indigo-700" %>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <%= link_to "Podgląd", admin_order_path(order), class: "text-indigo-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>