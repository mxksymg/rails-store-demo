<h1 class="text-2xl font-bold mb-4">Zamówienie nr <%= @order.id %></h1>
<p>Status: <%= @order.status %></p>
<p>Data płatności: <%= @order.paid_at || "nieopłacone" %></p>
<h2 class="text-xl font-semibold mt-4">Produkty</h2>
<ul class="list-disc pl-5">
  <% @order.order_items.each do |item| %>
    <li><%= item.product.name %> – ilość: <%= item.quantity %>, cena: <%= number_to_currency(item.price) %></li>
  <% end %>
</ul>
<%= link_to "Powrót do strony głównej", root_path, class: "mt-6 inline-block text-indigo-600" %>