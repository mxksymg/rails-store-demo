<h1 class="text-2xl font-bold mb-4">Podsumowanie zamówienia</h1>
<p class="mb-4">Całkowita kwota: <strong><%= number_to_currency(current_user.cart.total_price) %></strong></p>

<form action="/orders" method="post">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
  <input type="submit" value="Zamawiam i płacę (demo BLIK)" class="bg-blue-600 text-white px-4 py-2 rounded cursor-pointer">
</form>