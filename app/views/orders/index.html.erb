<h1 class="text-2xl font-bold mb-4">Moje zamówienia</h1>

<% if @orders.any? %>
  <div class="overflow-x-auto">
    <table class="min-w-full bg-white border">
      <thead>
        <tr>
          <th class="py-2 px-4 border-b">Nr zamówienia</th>
          <th class="py-2 px-4 border-b">Data</th>
          <th class="py-2 px-4 border-b">Kwota</th>
          <th class="py-2 px-4 border-b">Status</th>
          <th class="py-2 px-4 border-b">Data płatności</th>
          <th class="py-2 px-4 border-b"></th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td class="py-2 px-4 border-b"><%= order.id %></td>
            <td class="py-2 px-4 border-b"><%= order.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="py-2 px-4 border-b"><%= number_to_currency(order.total) %></td>
            <td class="py-2 px-4 border-b"><%= order.status %></td>
            <td class="py-2 px-4 border-b"><%= order.paid_at&.strftime("%Y-%m-%d %H:%M") || "brak" %></td>
            <td class="py-2 px-4 border-b"><%= link_to "Szczegóły", order_path(order), class: "text-indigo-600 hover:underline" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p>Nie masz jeszcze żadnych zamówień. <%= link_to "Zacznij zakupy", products_path, class: "text-indigo-600" %></p>
<% end %>